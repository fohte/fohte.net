    "@fontsource/ibm-plex-mono": "5.2.7",
    "@fontsource/noto-sans-jp": "5.2.9",
    "@radix-ui/react-slot": "1.2.5",
    "@tailwindcss/vite": "4.3.2",
    "@types/node": "25.0.3",
    "astro": "7.1.0",
    "astro-embed": "0.13.1",
    "date-fns": "4.1.0",
    "feed": "4.2.2",
    "gray-matter": "4.0.3",
    "mdast-util-to-string": "4.0.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "remark-breaks": "4.0.0",
    "remark-gfm": "4.0.1",
    "remark-mdx": "3.1.1",
    "remark-parse": "11.0.0",
    "remark-unwrap-images": "4.0.1",
    "satori": "0.25.0",
    "sharp": "0.35.0",
    "tailwindcss": "4.3.2",
    "unified": "11.0.5",
    "unist-util-visit": "5.1.0",
    "voyageai": "0.2.1"
