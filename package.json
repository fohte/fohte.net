  "devDependencies": {
    "@commitlint/cli": "21.2.1",
    "@eslint/eslintrc": "3.3.5",
    "@fohte/eslint-config": "0.3.6",
    "@iconify-json/simple-icons": "1.2.90",
    "@testing-library/jest-dom": "6.9.1",
    "@tsconfig/bun": "1.0.10",
    "@tsconfig/node-lts": "24.0.0",
    "@tsconfig/strictest": "2.0.8",
    "@types/bun": "1.3.14",
    "@types/jsdom": "28.0.3",
