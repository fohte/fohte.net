{
  "name": "fohte.net",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "lint": "eslint .",
    "format:eslint": "eslint --fix .",
    "format:prettier": "prettier --write .",
    "format": "conc -m 1 pnpm:format:eslint pnpm:format:prettier",
    "test": "conc -m 1 pnpm:test:type pnpm:test:unit",
    "test:type": "astro sync && tsc --noEmit",
    "test:unit": "vitest",
    "test:unit:ui": "vitest --ui",
    "test:unit:coverage": "vitest --coverage",
    "generate:embeddings": "node --import tsx/esm --import tsconfig-paths/register scripts/generate-embeddings.ts"
  },
  "dependencies": {
    "@astrojs/mdx": "5.0.3",
    "@astrojs/react": "5.0.2",
    "@astrojs/sitemap": "3.7.2",
    "@fontsource/ibm-plex-mono": "5.2.7",
    "@fontsource/noto-sans-jp": "5.2.9",
    "@radix-ui/react-slot": "1.2.4",
    "@tailwindcss/vite": "4.1.18",
    "@types/node": "25.0.3",
    "astro": "6.1.1",
    "astro-embed": "0.12.0",
    "date-fns": "4.1.0",
    "feed": "4.2.2",
    "gray-matter": "4.0.3",
    "mdast-util-to-string": "4.0.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "remark-breaks": "4.0.0",
    "remark-gfm": "4.0.1",
    "remark-mdx": "3.1.1",
    "remark-parse": "11.0.0",
    "remark-unwrap-images": "4.0.1",
    "satori": "0.26.0",
    "sharp": "0.34.5",
    "tailwindcss": "4.1.18",
    "unified": "11.0.5",
    "unist-util-visit": "5.1.0",
    "voyageai": "0.2.1"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.0",
    "@eslint/eslintrc": "3.3.5",
    "@fohte/eslint-config": "0.3.1",
    "@iconify-json/simple-icons": "1.2.77",
    "@testing-library/jest-dom": "6.6.3",
    "@tsconfig/bun": "1.0.10",
    "@types/bun": "1.3.10",
    "@types/jsdom": "28.0.1",
    "@types/mdx": "2.0.13",
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7",
    "@typescript-eslint/eslint-plugin": "8.57.2",
    "@typescript-eslint/parser": "8.57.2",
    "@vitejs/plugin-react": "5.2.0",
    "@vitest/ui": "4.1.2",
    "astro-icon": "1.1.5",
    "concurrently": "9.2.1",
    "eslint": "10.1.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import-x": "4.16.2",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "happy-dom": "17.6.3",
    "iconv-lite": "0.6.3",
    "jsdom": "26.1.0",
    "prettier": "3.8.1",
    "prettier-plugin-astro": "0.14.1",
    "prettier-plugin-tailwindcss": "0.7.2",
    "textlint": "14.0.4",
    "textlint-rule-preset-ja-technical-writing": "12.0.2",
    "tsconfig-paths": "4.2.0",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "4.1.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ],
    "overrides": {
      "@types/react": "18.3.28",
      "@types/react-dom": "18.3.7",
      "date-fns": "4.1.0"
    }
  },
  "license": "ISC"
}
