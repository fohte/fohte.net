    "@vitejs/plugin-react": "5.2.0",
    "@vitest/ui": "4.1.10",
    "astro-icon": "1.1.5",
    "concurrently": "10.0.3",
    "eslint": "10.6.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import-x": "4.17.1",
    "eslint-plugin-simple-import-sort": "13.0.0",
    "happy-dom": "20.10.6",
    "iconv-lite": "0.7.3",
