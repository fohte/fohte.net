                    {
                      "type": "text",
                      "id": "975R0",
                      "name": "bp3",
                      "fill": "$text-primary",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "まず init.vim を init.lua にリネームし、既存の設定を一つずつ lua の記法に書き換えていった。プラグインマネージャーは packer.nvim から lazy.nvim に変更した。",
                      "lineHeight": 1.8,
                      "fontFamily": "IBM Plex Mono",
                      "fontSize": 15,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "2QMDT",
                      "name": "bp4",
                      "fill": "$text-primary",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "キーマッピングの移行が最も手間がかかった部分で、vim.keymap.set を使って一つずつ書き直す必要があった。しかし lua の方が可読性が高く、結果的にメンテナンスしやすい設定になった。",
                      "lineHeight": 1.8,
                      "fontFamily": "IBM Plex Mono",
                      "fontSize": 15,
                      "fontWeight": "normal"
                    }
                  ]
