                      "fontSize": 11,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "tGNo9",
                      "name": "cb1",
                      "fill": "$text-primary",
                      "content": "vim.g.mapleader = ' '",
