---
import BaseLayout from '../layouts/BaseLayout.astro'
import { Counter } from '../components/astro/Counter'
---

<BaseLayout title="fohte.net" description="Fohte のポートフォリオサイト">
  <div class="mx-auto max-w-[780px] px-4 py-8 sm:px-6 md:px-8">
    <h2 class="mb-4 text-2xl font-bold text-gray-900">About</h2>
    <p class="mb-8 text-gray-600">
      Software Engineer。Web アプリケーション開発を中心に活動しています。
    </p>

    <section class="mb-8">
      <h3 class="mb-4 text-xl font-semibold text-gray-800">
        React Component Test
      </h3>
      <Counter client:load />
    </section>
  </div>
</BaseLayout>
