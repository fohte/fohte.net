---
import { getCollection } from 'astro:content'
import { format } from 'date-fns'

import BaseLayout from '../layouts/BaseLayout.astro'
import SocialList from '../components/astro/SocialList.astro'
import Tag from '../components/astro/Tag.astro'

const posts = await getCollection('posts')
const recentPosts = posts
  .filter((post) => !post.id.includes('e2e-test-'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3)
---

<BaseLayout>
  <div
    class="mx-auto flex max-w-[1280px] justify-center px-5 py-10 md:px-20 md:py-[60px]"
  >
    <div class="flex w-full max-w-[780px] flex-col gap-10">
      <!-- Hero -->
      <section class="flex flex-col gap-4">
        <span
          class="text-text-secondary font-[family-name:var(--font-mono-ui)] text-xs md:text-sm"
          >$ whoami</span
        >
        <h1
          class="font-[family-name:var(--font-mono-ui)] text-4xl font-bold md:text-5xl"
        >
          fohte
        </h1>
        <p class="text-text-secondary text-sm md:text-base">
          software engineer // infrastructure &amp; backend
        </p>
      </section>

      <hr class="border-border" />

      <!-- Links -->
      <section class="flex flex-col gap-4">
        <span
          class="text-text-tertiary font-[family-name:var(--font-mono-ui)] text-xs"
          >// links</span
        >
        <SocialList />
      </section>

      <hr class="border-border" />

      <!-- Career -->
      <section class="flex flex-col gap-4">
        <span
          class="text-text-tertiary font-[family-name:var(--font-mono-ui)] text-xs"
          >// career</span
        >
        <div class="flex items-center gap-4">
          <span
            class="text-text-tertiary font-[family-name:var(--font-mono-ui)] text-xs"
            >2020 - present</span
          >
          <span class="font-[family-name:var(--font-mono-ui)] text-sm"
            >software engineer</span
          >
        </div>
      </section>

      <hr class="border-border" />

      <!-- Recent Posts -->
      <section class="flex flex-col gap-4">
        <div class="flex items-center justify-between">
          <span
            class="text-text-tertiary font-[family-name:var(--font-mono-ui)] text-xs"
            >// recent posts</span
          >
          <a
            href="/blog"
            class="text-accent hover:text-text-primary flex items-center gap-1.5 font-[family-name:var(--font-mono-ui)] text-xs no-underline transition-colors"
          >
            all posts
            <span>&rarr;</span>
          </a>
        </div>
        <div class="flex flex-col gap-4">
          {
            recentPosts.map((post) => (
              <a
                href={`/blog/posts/${post.id}`}
                class="border-border hover:border-text-tertiary flex gap-4 border p-4 no-underline transition-colors"
              >
                {post.data.imagePath && (
                  <div class="hidden h-[120px] w-[200px] shrink-0 overflow-hidden md:block">
                    <img
                      src={post.data.imagePath}
                      alt=""
                      class="h-full w-full object-cover"
                    />
                  </div>
                )}
                <div class="flex flex-col gap-2">
                  <time
                    class="text-text-tertiary font-[family-name:var(--font-mono-ui)] text-[11px]"
                    datetime={post.data.date.toISOString()}
                  >
                    {format(post.data.date, 'yyyy-MM-dd')}
                  </time>
                  <h3 class="text-text-primary font-[family-name:var(--font-mono-ui)] text-[15px] font-medium">
                    {post.data.title}
                  </h3>
                  {post.data.tags && post.data.tags.length > 0 && (
                    <div class="flex flex-wrap gap-1.5">
                      {post.data.tags.map((tag) => (
                        <Tag tag={tag} />
                      ))}
                    </div>
                  )}
                </div>
              </a>
            ))
          }
        </div>
      </section>
    </div>
  </div>
</BaseLayout>
