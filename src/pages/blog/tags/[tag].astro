---
import { getCollection } from 'astro:content'
import { format } from 'date-fns'

import BaseLayout from '@/layouts/BaseLayout.astro'

export async function getStaticPaths() {
  const posts = await getCollection('posts')
  const allTags = new Set<string>()
  posts.forEach((post) => {
    post.data.tags?.forEach((tag) => allTags.add(tag))
  })

  return Array.from(allTags).map((tag) => ({
    params: { tag },
    props: {
      tag,
      posts: posts
        .filter((post) => post.data.tags?.includes(tag))
        .filter((post) => !post.id.includes('e2e-test-'))
        .sort((a, b) => b.data.date.getTime() - a.data.date.getTime()),
    },
  }))
}

const { tag, posts } = Astro.props
---

<BaseLayout title={`${tag} の記事一覧`}>
  <div class="mx-auto max-w-[780px] bg-white px-4 py-8 sm:px-6 md:px-8">
    <h1 class="my-4 text-xl font-semibold">
      <span class="text-gray-500"># {tag}</span> の記事一覧
    </h1>
    <ul>
      {
        posts.map((post, index) => (
          <li
            class:list={[
              'py-4',
              index !== posts.length - 1 && 'mb-2 border-b border-gray-300',
            ]}
          >
            <a
              href={`/blog/posts/${post.id}`}
              class="block text-black hover:no-underline focus:outline-none"
            >
              <time
                class="mb-2 block text-sm text-gray-500"
                datetime={post.data.date.toISOString()}
              >
                {format(post.data.date, 'yyyy-MM-dd')}
              </time>
              <h2 class="text-xl font-semibold">{post.data.title}</h2>
            </a>
            {post.data.tags && post.data.tags.length > 0 && (
              <ul class="mt-2 flex flex-wrap gap-1">
                {post.data.tags.map((t) => (
                  <li>
                    <a
                      href={`/blog/tags/${t}`}
                      class:list={[
                        'inline-block px-2 py-1 text-sm',
                        t === tag
                          ? 'bg-gray-200 text-gray-700'
                          : 'bg-gray-100 text-gray-500 hover:bg-gray-200',
                      ]}
                    >
                      # {t}
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </li>
        ))
      }
    </ul>
  </div>
</BaseLayout>
