---
import { getCollection } from 'astro:content'
import { format } from 'date-fns'

import BaseLayout from '@/layouts/BaseLayout.astro'

const posts = await getCollection('posts')
const sortedPosts = posts
  .filter((post) => !post.id.includes('e2e-test-'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
---

<BaseLayout title="記事一覧">
  <div class="mx-auto max-w-[780px] bg-white px-4 py-8 sm:px-6 md:px-8">
    <h1 class="my-4 text-xl font-semibold">記事一覧</h1>
    <ul>
      {
        sortedPosts.map((post, index) => (
          <li
            class:list={[
              'py-4',
              index !== sortedPosts.length - 1 &&
                'mb-2 border-b border-gray-300',
            ]}
          >
            <a
              href={`/blog/posts/${post.id}`}
              class="block text-black hover:no-underline focus:outline-none"
            >
              <time
                class="mb-2 block text-sm text-gray-500"
                datetime={post.data.date.toISOString()}
              >
                {format(post.data.date, 'yyyy-MM-dd')}
              </time>
              <h2 class="text-xl font-semibold">{post.data.title}</h2>
            </a>
            {post.data.tags && post.data.tags.length > 0 && (
              <ul class="mt-2 flex flex-wrap gap-1">
                {post.data.tags.map((tag) => (
                  <li>
                    <a
                      href={`/blog/tags/${tag}`}
                      class="inline-block bg-gray-100 px-2 py-1 text-sm text-gray-500 hover:bg-gray-200"
                    >
                      # {tag}
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </li>
        ))
      }
    </ul>
  </div>
</BaseLayout>
