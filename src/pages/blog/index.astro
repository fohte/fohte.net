---
import { getCollection } from 'astro:content'

import BaseLayout from '@/layouts/BaseLayout.astro'
import PostList from '@/components/astro/PostList.astro'

const posts = await getCollection('posts')
const sortedPosts = posts
  .filter((post) => !post.id.includes('e2e-test-'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
---

<BaseLayout title="記事一覧">
  <div class="mx-auto max-w-[780px] bg-white px-4 py-8 sm:px-6 md:px-8">
    <h1 class="my-4 text-xl font-semibold">記事一覧</h1>
    <PostList posts={sortedPosts} />
  </div>
</BaseLayout>
