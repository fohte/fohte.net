---
import type { GetStaticPaths } from 'astro'
import { getCollection } from 'astro:content'

import BaseLayout from '@/layouts/BaseLayout.astro'
import PostList from '@/components/astro/PostList.astro'
import Tag from '@/components/astro/Tag.astro'

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const posts = await getCollection('posts')
  const sortedPosts = posts
    .filter((post) => !post.id.includes('e2e-test-'))
    .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())

  return paginate(sortedPosts, { pageSize: 10 })
}

const { page } = Astro.props

const allPosts = await getCollection('posts')
const publishedPosts = allPosts.filter((post) => !post.id.includes('e2e-test-'))
const allTags = new Set<string>()
publishedPosts.forEach((post) => {
  post.data.tags?.forEach((tag) => allTags.add(tag))
})
const tags = Array.from(allTags).sort()
---

<BaseLayout title="blog">
  <div
    class="mx-auto flex max-w-[1280px] gap-10 px-5 py-10 md:px-20 md:py-[60px]"
  >
    <!-- Article Area -->
    <div class="flex min-w-0 flex-1 flex-col gap-6">
      <div class="flex flex-col gap-2">
        <span
          class="text-text-secondary font-[family-name:var(--font-mono-ui)] text-sm"
          >$ ls ~/posts</span
        >
        <h1 class="font-[family-name:var(--font-mono-ui)] text-4xl font-bold">
          blog
        </h1>
      </div>
      <hr class="border-border" />
      <PostList posts={page.data} />

      <!-- Pagination -->
      {
        page.lastPage > 1 && (
          <nav class="flex items-center justify-center gap-4 font-[family-name:var(--font-mono-ui)] text-sm">
            {page.url.prev ? (
              <a
                href={page.url.prev}
                class="text-accent hover:text-text-primary no-underline transition-colors"
              >
                &lt; prev
              </a>
            ) : (
              <span class="text-text-tertiary">&lt; prev</span>
            )}
            <span class="text-text-secondary">
              {page.currentPage} / {page.lastPage}
            </span>
            {page.url.next ? (
              <a
                href={page.url.next}
                class="text-accent hover:text-text-primary no-underline transition-colors"
              >
                next &gt;
              </a>
            ) : (
              <span class="text-text-tertiary">next &gt;</span>
            )}
          </nav>
        )
      }

      <!-- Tags for SP (below post list) -->
      <div class="border-border border-t pt-6 lg:hidden">
        <span
          class="text-text-tertiary mb-4 block font-[family-name:var(--font-mono-ui)] text-[11px]"
          >// tags</span
        >
        <div class="flex flex-wrap gap-1.5">
          <Tag tag="all" active href="/blog" />
          {tags.map((tag) => <Tag tag={tag} href={`/blog/tags/${tag}`} />)}
        </div>
      </div>
    </div>

    <!-- Tag Sidebar (PC only) -->
    <aside
      class="border-border hidden w-[220px] shrink-0 border-l pl-6 lg:block"
    >
      <span
        class="text-text-tertiary mb-4 block font-[family-name:var(--font-mono-ui)] text-[11px]"
        >// tags</span
      >
      <div class="flex flex-wrap gap-1.5">
        <Tag tag="all" active href="/blog" />
        {tags.map((tag) => <Tag tag={tag} href={`/blog/tags/${tag}`} />)}
      </div>
    </aside>
  </div>
</BaseLayout>
