---
import { getCollection, getEntry, render } from 'astro:content'
import { format } from 'date-fns'

import BaseLayout from '@/layouts/BaseLayout.astro'
import RelatedPosts from '@/components/astro/RelatedPosts.astro'
import ShareButtons from '@/components/astro/ShareButtons.astro'
import Tag from '@/components/astro/Tag.astro'
import TocList from '@/components/astro/TocList.astro'
import { mdxComponents } from '@/components/mdx'

export async function getStaticPaths() {
  const posts = await getCollection('posts')
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }))
}

const { post } = Astro.props
const { Content, headings } = await render(post)
const formattedDate = format(post.data.date, 'yyyy-MM-dd')
const tocHeadings = headings.filter(
  (h) => h.depth <= 3 && h.slug !== 'footnote-label',
)
const ogImage = post.data.imagePath || `/og/${post.id}.png`
const postUrl = `https://fohte.net/blog/posts/${post.id}`

// Fetch related posts data (gracefully handles missing relatedPosts collection)
// try-catch is intentional: the relatedPosts collection loader is not yet
// integrated (task 4.1), so getEntry would throw at build time without it.
const relatedPostsData = await (async () => {
  try {
    const relatedEntry = await getEntry('relatedPosts', post.id)
    if (!relatedEntry) return []
    const entries = await Promise.all(
      relatedEntry.data.relatedSlugs.map(({ slug }: { slug: string }) =>
        getEntry('posts', slug),
      ),
    )
    return entries
      .filter((p): p is NonNullable<typeof p> => p != null)
      .map((p) => ({
        slug: p.id,
        title: p.data.title,
        date: p.data.date,
        url: `/blog/posts/${p.id}`,
        description: p.data.description,
        tags: p.data.tags,
      }))
  } catch {
    // relatedPosts collection not yet available
    return []
  }
})()
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  ogType="article"
  ogImage={ogImage}
  fediverseCreator="@fohte@social.fohte.net"
>
  <div
    class="mx-auto flex max-w-[1280px] gap-10 px-5 py-10 md:px-20 md:py-[60px]"
  >
    <!-- Article Area -->
    <article class="flex max-w-[780px] min-w-0 flex-1 flex-col gap-8">
      <!-- Post Header -->
      <header class="flex flex-col gap-3">
        <span
          class="text-text-secondary font-[family-name:var(--font-mono-ui)] text-[13px]"
        >
          $ cat ~/posts/{post.id}.mdx
        </span>
        <div class="flex items-center gap-3">
          <time
            class="text-text-tertiary font-[family-name:var(--font-mono-ui)] text-xs"
            datetime={post.data.date.toISOString()}
          >
            {formattedDate}
          </time>
          {
            post.data.tags && post.data.tags.length > 0 && (
              <div class="flex flex-wrap gap-1.5">
                {post.data.tags.map((tag) => (
                  <Tag tag={tag} href={`/blog/tags/${tag}`} />
                ))}
              </div>
            )
          }
        </div>
        <h1 class="text-2xl leading-tight font-bold md:text-3xl">
          {post.data.title}
        </h1>
      </header>

      <!-- TOC for SP (collapsible, above article) -->
      {
        tocHeadings.length > 0 && (
          <div class="border-border bg-bg-secondary border p-4 lg:hidden">
            <details>
              <summary class="text-text-tertiary cursor-pointer font-[family-name:var(--font-mono-ui)] text-[11px]">
                // table of contents
              </summary>
              <nav class="mt-3">
                <TocList headings={tocHeadings} />
              </nav>
            </details>
          </div>
        )
      }

      {
        post.data.imagePath && (
          <div class="h-[300px] overflow-hidden md:h-[400px]">
            <img
              src={post.data.imagePath}
              alt=""
              class="h-full w-full object-cover"
            />
          </div>
        )
      }

      <hr class="border-border" />

      <!-- Article Body -->
      <div class="article-body text-sm leading-loose md:text-base">
        <Content components={mdxComponents} />
      </div>

      <hr class="border-border" />

      <ShareButtons url={postUrl} title={post.data.title} />

      <RelatedPosts relatedPosts={relatedPostsData} />

      <!-- Back Link -->
      <a
        href="/blog"
        class="text-text-primary hover:text-accent flex items-center gap-2 font-[family-name:var(--font-mono-ui)] text-sm no-underline transition-colors"
      >
        <span class="text-accent font-bold">&lt;</span>
        back to blog
      </a>
    </article>

    <!-- TOC Sidebar (PC only) -->
    {
      tocHeadings.length > 0 && (
        <aside class="border-border hidden w-[220px] shrink-0 border-l pl-6 lg:block">
          <span class="text-text-tertiary mb-4 block font-[family-name:var(--font-mono-ui)] text-[11px]">
            // table of contents
          </span>
          <nav>
            <TocList headings={tocHeadings} />
          </nav>
        </aside>
      )
    }
  </div>
</BaseLayout>

<script>
  if (document.querySelector('.twitter-tweet')) {
    const script = document.createElement('script')
    script.src = 'https://platform.twitter.com/widgets.js'
    script.async = true
    document.head.appendChild(script)
  }
</script>
