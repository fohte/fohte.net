---
import BaseLayout from '../../layouts/BaseLayout.astro'

const originals = [
  {
    title: 'Scafohld',
    href: 'https://assets.fohte.net/projects/bms/Scafohld.zip',
    listen: {
      text: 'SoundCloud',
      href: 'https://soundcloud.com/fohte/scafohld',
    },
    description: '「第 10 回自称無名 BMS 作家が物申す!」参加曲',
    eventHref:
      'https://manbow.nothing.sh/event/event.cgi?action=More_def&num=36&event=86',
  },
]

const diffs = [
  {
    level: '★16 (?)',
    title: 'Absurd Gaff [Fohter]',
    href: 'https://assets.fohte.net/projects/bms/_abs07_Fohte.bme',
    video: { text: 'YouTube', href: 'https://youtube.com/watch?v=X8XMcAHMwks' },
    ir: {
      text: 'LR2',
      href: 'http://dream-pro.info/~lavalse/LR2IR/search.cgi?mode=ranking&bmsid=146845',
    },
    note: '初差分作成。同梱穴譜面の密度を高くした感じ。',
  },
  {
    level: '★12 (?)',
    title: 'time from nostalgia [Fohter]',
    href: 'https://assets.fohte.net/projects/bms/_nostalgia_fohter.bml',
    video: { text: 'YouTube', href: 'https://youtube.com/watch?v=BqkY8fa3iWg' },
    ir: {
      text: 'LR2',
      href: 'http://dream-pro.info/~lavalse/LR2IR/search.cgi?mode=ranking&bmsid=146995',
    },
    note: '同時押しマシマシ',
  },
  {
    level: '★18 (?)',
    title: 'Andromeda [Fohter]',
    href: 'https://assets.fohte.net/projects/bms/andromeda_fohter.bme',
    video: null,
    ir: {
      text: 'LR2',
      href: 'http://dream-pro.info/~lavalse/LR2IR/search.cgi?mode=ranking&bmsid=148565',
    },
    note: 'quell + Almagest',
  },
  {
    level: '★★2 (?)',
    title: 'Angelic layer 玄人',
    href: 'https://assets.fohte.net/projects/bms/angelic7Fohter.bme',
    video: null,
    ir: {
      text: 'LR2',
      href: 'http://dream-pro.info/~lavalse/LR2IR/search.cgi?mode=ranking&bmsid=166050',
    },
    note: '某 Overjoy 譜面の密度を薄くして長い縦連も少し崩した譜面。でもやっぱり難しい。',
  },
  {
    level: '★18 (?)',
    title: 'Akasagarbha -PRO-',
    href: 'https://assets.fohte.net/projects/bms/_akasagarbha_7fo.bme',
    video: { text: 'YouTube', href: 'https://youtube.com/watch?v=LlXyMes0ubE' },
    ir: {
      text: 'LR2',
      href: 'http://dream-pro.info/~lavalse/LR2IR/search.cgi?mode=ranking&bmsid=166048',
    },
    note: 'ブレイク明け寸前から発狂する感じのラス殺し譜面が一度作ってみたかった。無音ノーツ・手動ディレイほんの少し有り。',
  },
  {
    level: '★5 (?)',
    title: 'ロッカー -STREAM-',
    href: 'https://assets.fohte.net/projects/bms/locker(F).bms',
    video: { text: 'YouTube', href: 'https://youtube.com/watch?v=thgTUGAWavA' },
    ir: {
      text: 'LR2',
      href: 'http://dream-pro.info/~lavalse/LR2IR/search.cgi?mode=ranking&bmsid=166252',
    },
    note: '発狂低難易度を目指して作ってみた。高速曲も相まって難しめになってた。BPM 194 の 16 分トリルや簡単な皿複合あり。',
  },
]
---

<BaseLayout title="BMS products">
  <div
    class="mx-auto flex max-w-[1280px] justify-center px-5 py-10 md:px-20 md:py-[60px]"
  >
    <div class="flex w-full max-w-[780px] flex-col gap-8">
      <div class="flex flex-col gap-2">
        <span
          class="text-text-secondary font-[family-name:var(--font-mono-ui)] text-sm"
          >$ ls ~/projects/bms</span
        >
        <h1 class="font-[family-name:var(--font-mono-ui)] text-4xl font-bold">
          bms
        </h1>
        <p class="text-text-secondary text-sm">
          BMS (Be-Music Source) の楽曲と差分譜面の一覧。
        </p>
      </div>

      <hr class="border-border" />

      <!-- Originals -->
      <section class="flex flex-col gap-4">
        <div class="flex items-center gap-2">
          <span
            class="text-accent font-[family-name:var(--font-mono-ui)] text-[13px] font-bold"
            >##</span
          >
          <h2 class="font-[family-name:var(--font-mono-ui)] text-xl font-bold">
            originals
          </h2>
        </div>
        <div class="overflow-x-auto">
          <table
            class="w-full border-collapse font-[family-name:var(--font-mono-body)] text-sm"
          >
            <thead>
              <tr class="border-border border-b">
                <th class="text-text-secondary px-3 py-2 text-left">title</th>
                <th class="text-text-secondary px-3 py-2 text-left">listen</th>
                <th class="text-text-secondary px-3 py-2 text-left">note</th>
              </tr>
            </thead>
            <tbody>
              {
                originals.map((item) => (
                  <tr class="border-border border-b">
                    <td class="px-3 py-2">
                      <a
                        href={item.href}
                        class="text-text-primary hover:text-accent no-underline"
                        target="_blank"
                        rel="noopener noreferrer"
                      >
                        {item.title}
                      </a>
                    </td>
                    <td class="px-3 py-2">
                      <a
                        href={item.listen.href}
                        class="text-accent hover:text-text-primary no-underline"
                        target="_blank"
                        rel="noopener noreferrer"
                      >
                        {item.listen.text}
                      </a>
                    </td>
                    <td class="text-text-secondary px-3 py-2">
                      {item.description}{' '}
                      {item.eventHref && (
                        <a
                          href={item.eventHref}
                          class="text-accent hover:text-text-primary no-underline"
                          target="_blank"
                          rel="noopener noreferrer"
                        >
                          (event)
                        </a>
                      )}
                    </td>
                  </tr>
                ))
              }
            </tbody>
          </table>
        </div>
      </section>

      <!-- Diffs -->
      <section class="flex flex-col gap-4">
        <div class="flex items-center gap-2">
          <span
            class="text-accent font-[family-name:var(--font-mono-ui)] text-[13px] font-bold"
            >##</span
          >
          <h2 class="font-[family-name:var(--font-mono-ui)] text-xl font-bold">
            diffs
          </h2>
        </div>
        <div class="overflow-x-auto">
          <table
            class="w-full border-collapse font-[family-name:var(--font-mono-body)] text-sm"
          >
            <thead>
              <tr class="border-border border-b">
                <th class="text-text-secondary px-3 py-2 text-left">level</th>
                <th class="text-text-secondary px-3 py-2 text-left">title</th>
                <th class="text-text-secondary px-3 py-2 text-left">video</th>
                <th class="text-text-secondary px-3 py-2 text-left">IR</th>
                <th class="text-text-secondary px-3 py-2 text-left">note</th>
              </tr>
            </thead>
            <tbody>
              {
                diffs.map((item) => (
                  <tr class="border-border border-b">
                    <td class="text-text-tertiary px-3 py-2 whitespace-nowrap">
                      {item.level}
                    </td>
                    <td class="px-3 py-2">
                      <a
                        href={item.href}
                        class="text-text-primary hover:text-accent no-underline"
                        target="_blank"
                        rel="noopener noreferrer"
                      >
                        {item.title}
                      </a>
                    </td>
                    <td class="px-3 py-2">
                      {item.video ? (
                        <a
                          href={item.video.href}
                          class="text-accent hover:text-text-primary no-underline"
                          target="_blank"
                          rel="noopener noreferrer"
                        >
                          {item.video.text}
                        </a>
                      ) : (
                        <span class="text-text-tertiary">-</span>
                      )}
                    </td>
                    <td class="px-3 py-2">
                      <a
                        href={item.ir.href}
                        class="text-accent hover:text-text-primary no-underline"
                        target="_blank"
                        rel="noopener noreferrer"
                      >
                        {item.ir.text}
                      </a>
                    </td>
                    <td class="text-text-secondary px-3 py-2">{item.note}</td>
                  </tr>
                ))
              }
            </tbody>
          </table>
        </div>
      </section>

      <hr class="border-border" />

      <!-- Back Link -->
      <a
        href="/projects"
        class="text-text-primary hover:text-accent flex items-center gap-2 font-[family-name:var(--font-mono-ui)] text-sm no-underline transition-colors"
      >
        <span class="text-accent font-bold">&lt;</span>
        back to projects
      </a>
    </div>
  </div>
</BaseLayout>
