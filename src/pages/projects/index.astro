---
import BaseLayout from '../../layouts/BaseLayout.astro'
import Tag from '../../components/astro/Tag.astro'

const projects = [
  {
    title: 'BMS',
    description: 'BMS 曲と作った差分。',
    href: '/projects/bms',
    tags: ['music', 'bms'],
  },
  {
    title: 'fohte.net',
    description:
      'このサイト。Astro + Tailwind CSS で構築した個人サイト。ターミナルライクなデザインを採用。',
    href: 'https://github.com/fohte/fohte.net',
    tags: ['web', 'astro'],
  },
]
---

<BaseLayout title="projects">
  <div
    class="mx-auto flex max-w-[1280px] justify-center px-5 py-10 md:px-20 md:py-[60px]"
  >
    <div class="flex w-full max-w-[780px] flex-col gap-8">
      <div class="flex flex-col gap-2">
        <span
          class="text-text-secondary font-[family-name:var(--font-mono-ui)] text-sm"
          >$ ls ~/projects</span
        >
        <h1 class="font-[family-name:var(--font-mono-ui)] text-4xl font-bold">
          projects
        </h1>
      </div>

      <hr class="border-border" />

      <div class="flex flex-col gap-6">
        {
          projects.map((project) => (
            <a
              href={project.href}
              class="border-border hover:border-text-tertiary flex flex-col gap-3 border p-6 no-underline transition-colors"
              target={project.href.startsWith('http') ? '_blank' : undefined}
              rel={
                project.href.startsWith('http')
                  ? 'noopener noreferrer'
                  : undefined
              }
            >
              <div class="flex items-center justify-between">
                <h2 class="text-text-primary text-lg font-bold">
                  {project.title}
                </h2>
                <span class="text-accent font-[family-name:var(--font-mono-ui)] text-sm font-bold">
                  &gt;&gt;
                </span>
              </div>
              <p class="text-text-secondary text-sm leading-relaxed">
                {project.description}
              </p>
              <div class="flex flex-wrap gap-1.5">
                {project.tags.map((tag) => (
                  <Tag tag={tag} />
                ))}
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </div>
</BaseLayout>
