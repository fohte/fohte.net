---
interface Props {
  siteTitle?: string
}

const { siteTitle = 'fohte.net' } = Astro.props

const navLinks = [
  { href: '/', label: 'About' },
  { href: '/projects', label: 'Projects' },
  { href: '/blog', label: 'Blog' },
]
---

<header>
  <div class="mx-auto flex max-w-[780px] items-center justify-between px-4 py-6 sm:px-6 md:px-8">
    <h1 class="text-xl font-bold leading-tight">
      <a href="/" class="flex items-center gap-4 text-black no-underline hover:opacity-80">
        <img src="/icon.png" alt="" class="h-[1.5em] w-[1.5em]" />
        <span>{siteTitle}</span>
      </a>
    </h1>
    <nav>
      <ul class="flex items-center gap-6">
        {
          navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-black no-underline hover:opacity-80"
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>
