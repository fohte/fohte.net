---

---

<footer class="border-border border-t">
  <div
    class="mx-auto flex h-[60px] max-w-[1280px] items-center justify-between px-5 md:px-20"
  >
    <span
      class="text-text-tertiary font-[family-name:var(--font-mono-body)] text-xs"
    >
      &copy; 2020 fohte
    </span>
    <div class="flex items-center gap-4">
      <button
        id="theme-toggle"
        type="button"
        class="text-text-tertiary hover:text-text-secondary font-[family-name:var(--font-mono-ui)] text-xs transition-colors"
        aria-label="Toggle theme"
      >
        <span id="theme-label">theme: dark</span>
      </button>
      <a
        href="/privacy-policy"
        class="text-text-tertiary hover:text-text-secondary font-[family-name:var(--font-mono-ui)] text-xs no-underline transition-colors"
      >
        privacy_policy
      </a>
    </div>
  </div>
</footer>

<script>
  const btn = document.getElementById('theme-toggle')!
  const label = document.getElementById('theme-label')!
  const root = document.documentElement

  function updateLabel() {
    const isDark = root.classList.contains('dark')
    label.textContent = `theme: ${isDark ? 'dark' : 'light'}`
  }

  updateLabel()

  btn.addEventListener('click', () => {
    const isDark = root.classList.contains('dark')
    root.classList.replace(isDark ? 'dark' : 'light', isDark ? 'light' : 'dark')
    localStorage.setItem('theme', isDark ? 'light' : 'dark')
    updateLabel()
  })
</script>
