---
const currentYear = new Date().getFullYear()
const startYear = 2020
const yearDisplay = currentYear === startYear ? `${startYear}` : `${startYear}-${currentYear}`
---

<footer class="mt-auto border-t border-gray-200 bg-white">
  <div class="mx-auto max-w-[780px] px-4 py-6 sm:px-6 md:px-8">
    <div class="flex flex-wrap items-center justify-center gap-6 text-sm text-gray-500">
      <span>&copy; {yearDisplay} Fohte</span>
      <a href="/privacy-policy" class="text-gray-500 no-underline hover:text-gray-700">
        Privacy Policy
      </a>
    </div>
  </div>
</footer>
