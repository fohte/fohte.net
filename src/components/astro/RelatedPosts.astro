---
import { format } from 'date-fns'
import Tag from './Tag.astro'

interface RelatedPost {
  slug: string
  title: string
  date: Date
  url: string
  description?: string
  tags?: string[]
}

interface Props {
  relatedPosts: RelatedPost[]
}

const { relatedPosts } = Astro.props
---

{
  relatedPosts.length > 0 && (
    <section class="flex flex-col gap-4">
      <span class="text-text-tertiary font-[family-name:var(--font-mono-ui)] text-[11px]">
        // related posts
      </span>
      <div class="flex flex-col gap-4">
        {relatedPosts.map((post) => (
          <a
            href={post.url}
            class="border-border bg-bg-secondary hover:border-text-tertiary block border no-underline transition-colors"
          >
            <div class="flex flex-col gap-1.5 p-5">
              <time
                class="text-text-tertiary block font-[family-name:var(--font-mono-ui)] text-[11px]"
                datetime={post.date.toISOString()}
              >
                {format(post.date, 'yyyy-MM-dd')}
              </time>
              <h3 class="text-text-primary text-base font-semibold">
                {post.title}
              </h3>
              {post.description && (
                <p class="text-text-secondary text-sm">{post.description}</p>
              )}
              {post.tags && post.tags.length > 0 && (
                <div class="mt-1 flex flex-wrap gap-1.5">
                  {post.tags.map((tag) => (
                    <Tag tag={tag} />
                  ))}
                </div>
              )}
            </div>
          </a>
        ))}
      </div>
    </section>
  )
}
