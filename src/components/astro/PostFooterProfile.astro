---
import { socialLinks } from '@/data/socialLinks'
---

<div class="flex items-center gap-3 py-5 md:gap-4 md:py-6">
  <img
    src="/icon.png"
    alt="Fohte's profile icon"
    class="h-12 w-12 rounded-full md:h-14 md:w-14"
  />
  <div class="flex flex-col gap-2 md:gap-2.5">
    <span
      class="text-text-primary font-[family-name:var(--font-mono-ui)] text-[13px] font-bold md:text-sm"
      >Fohte</span
    >
    <ul class="flex items-center gap-2.5 md:gap-3">
      {
        socialLinks.map((social) => (
          <li>
            <a
              href={social.href}
              class="border-border text-text-secondary hover:text-accent hover:border-accent flex h-8 w-8 items-center justify-center rounded-lg border transition-colors md:h-9 md:w-9"
              target="_blank"
              rel={
                social.rel
                  ? `${social.rel} noopener noreferrer`
                  : 'noopener noreferrer'
              }
              aria-label={social.name}
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                class="h-3.5 w-3.5 md:h-4 md:w-4"
                fill="currentColor"
                aria-hidden="true"
              >
                <path d={social.svgPath} />
              </svg>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</div>
