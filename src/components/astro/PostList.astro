---
import type { CollectionEntry } from 'astro:content'
import { format } from 'date-fns'
import Tag from './Tag.astro'

interface Props {
  posts: CollectionEntry<'posts'>[]
  activeTag?: string
}

const { posts, activeTag } = Astro.props
---

<div class="flex flex-col gap-4">
  {
    posts.map((post) => (
      <a
        href={`/blog/posts/${post.id}`}
        class="border-border hover:border-text-tertiary block border p-4 no-underline transition-colors"
      >
        <time
          class="text-text-tertiary mb-2 block font-[family-name:var(--font-mono-ui)] text-[11px]"
          datetime={post.data.date.toISOString()}
        >
          {format(post.data.date, 'yyyy-MM-dd')}
        </time>
        <h2 class="text-text-primary mb-2 font-[family-name:var(--font-mono-ui)] text-[15px] font-medium">
          {post.data.title}
        </h2>
        {post.data.description && (
          <p class="text-text-secondary mb-2 text-sm">
            {post.data.description}
          </p>
        )}
        {post.data.tags && post.data.tags.length > 0 && (
          <div class="flex flex-wrap gap-1.5">
            {post.data.tags.map((tag) => (
              <Tag tag={tag} active={tag === activeTag} />
            ))}
          </div>
        )}
      </a>
    ))
  }
</div>
